# ─────────────────────────────────────────────────────────────────────────────
# Server Analysis Backend — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Express Server Port ───────────────────────────────────────────────────────
PORT=3971

# ── MongoDB Connection URI ────────────────────────────────────────────────────
# Production (remote MongoDB on 217.145.69.228):
MONGODB_URI=mongodb://admin:YOUR_MONGO_PASSWORD@217.145.69.228:27017/server_analysis?authSource=admin
#
# Local development alternative:
# MONGODB_URI=mongodb://127.0.0.1:27017/server_analysis
#
# MongoDB Atlas alternative:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/server_analysis

# ── DB History Seeding ────────────────────────────────────────────────────────
# Set to 'true' to auto-generate 7 weeks of dummy historical data when a new
# server first connects. Set to 'false' (default) to show only real metrics.
SEED_DUMMY_HISTORY=false

# ── Email Alert Notifications (Optional) ──────────────────────────────────────
# Configure to receive email alerts when server CPU/RAM exceeds 90%.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_RECIPIENT=

# ── Webhook Alert Notifications (Optional) ────────────────────────────────────
# Paste your Slack or Discord webhook URL to receive critical alerts.
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
