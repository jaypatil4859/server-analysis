# ─────────────────────────────────────────────────────────────────────────────
# Root-level .env.example — Nagios Bridge & Shared Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Connection ────────────────────────────────────────────────────────
# Production MongoDB on 217.145.69.228
MONGODB_URI=mongodb://admin:YOUR_MONGO_PASSWORD@217.145.69.228:27017/server_analysis?authSource=admin

# ── Nagios Bridge Configuration ───────────────────────────────────────────────
# URL of the Nagios web interface
NAGIOS_URL=http://217.145.69.228/nagios

# Nagios admin credentials
NAGIOS_USER=nagiosadmin
NAGIOS_PASS=YOUR_NAGIOS_PASSWORD

# How often to poll Nagios for new data (in milliseconds)
# Default: 30000 (30 seconds)
POLL_INTERVAL_MS=30000

# ── SSH Access (Optional - for ssh-collector.js only) ────────────────────────
# Only required if using the SSH-based collector instead of Nagios bridge.
# SSH_USER=root
# SSH_KEY_PATH=/home/devops/.ssh/id_rsa

# ── Email Alert Notifications (Optional) ─────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL_RECIPIENT=devops@yourcompany.com

# ── Slack/Discord Webhook Alerts (Optional) ───────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
